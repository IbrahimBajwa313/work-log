# MongoDB
MONGODB_URI=
MONGODB_DB_NAME=worklog

# User session JWT (required in production)
WORKLOG_SESSION_SECRET=

# Admin panel
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Google OAuth (optional — enables "Continue with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; defaults to {your-app-url}/api/auth/google/callback
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
